{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "byrRadar",
  "version": "0.1.0",
  "identifier": "com.byrradar.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "byrRadar",
